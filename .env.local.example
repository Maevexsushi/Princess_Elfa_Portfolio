# Contact form email delivery (Gmail SMTP via App Password)
#
# 1. Enable 2-Step Verification on the Google account.
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password (remove spaces) into GMAIL_APP_PASSWORD.
# 4. Copy this file to `.env.local` and fill in the values.
#
# In production (Vercel), set these in Project Settings → Environment Variables.

GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=your16charapppass

# Optional: where contact submissions are delivered.
# Defaults to GMAIL_USER if omitted.
CONTACT_TO=your-address@gmail.com
